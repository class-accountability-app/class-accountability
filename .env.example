# Copy to .env.local and fill in. NEVER commit .env.local.
# Real values live in Vercel env vars and GitHub Actions secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY. Bypasses row-level security.
# Must never be prefixed NEXT_PUBLIC_ and must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Docs integration (Sprint 4) ---
# Scope: drive.file only — access ONLY to files the user explicitly picks.
# Do NOT request drive.readonly (that would grant their entire Drive).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# University email domain allowed to sign up (enrollment check, MVP-level)
ALLOWED_EMAIL_DOMAIN=
